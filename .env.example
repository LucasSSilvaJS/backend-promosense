# API
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE=PromoSense API
API_VERSION=1.0.0
ENVIRONMENT=development

# Dados
CSV_FILE_PATH=olist_processado.csv
JSON_FILE_PATH=data/avaliacoes.json

# Segurança — altere API_KEY antes de deploy
AUTH_ENABLED=true
API_KEY=defina-uma-chave-forte-aqui
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://promosense.vercel.app
ALLOWED_HOSTS=backend-promosense.onrender.com,localhost,127.0.0.1
DOCS_ENABLED=true
API_PUBLIC_URL=https://backend-promosense.onrender.com
